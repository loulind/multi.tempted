Package: multi.tempted
Type: Package
Title: Dimensionality Reduction of Longitudinal Multiomic Data
Version: 0.1.0
Depends: R (>= 4.5.0)
Authors@R: c(
    person(
      "Lou", "Lindsley",
      email = "4loubird@gmail.com",
